<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.destino.app.view.NotasController"
            prefWidth="900" prefHeight="500">

    <top>
        <VBox spacing="8">
            <padding><Insets top="12" left="12" right="12" bottom="8"/></padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="← Volver" onAction="#onVolver"/>
                <Label text="Notas de seguimiento" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Persona:"/>
                <ComboBox fx:id="comboPersona" prefWidth="280"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tablaNotas">
            <columns>
                <TableColumn fx:id="colFecha" text="Fecha" prefWidth="100"/>
                <TableColumn fx:id="colTipo" text="Tipo" prefWidth="100"/>
                <TableColumn fx:id="colDescripcion" text="Nota" prefWidth="320"/>
                <TableColumn fx:id="colAutor" text="Autor" prefWidth="150"/>
            </columns>
            <BorderPane.margin><Insets left="12" bottom="12"/></BorderPane.margin>
        </TableView>
    </center>

    <right>
        <VBox spacing="8" prefWidth="250">
            <padding><Insets top="0" right="12" bottom="12" left="12"/></padding>
            <Label text="Nueva nota" style="-fx-font-weight: bold;"/>
            <ComboBox fx:id="comboTipo" promptText="Tipo" prefWidth="220"/>
            <TextArea fx:id="campoDescripcion" promptText="Descripción" prefRowCount="5"/>
            <Button text="Registrar nota" onAction="#onRegistrar" defaultButton="true"/>
            <Label fx:id="etiquetaMensaje" wrapText="true"/>
        </VBox>
    </right>
</BorderPane>