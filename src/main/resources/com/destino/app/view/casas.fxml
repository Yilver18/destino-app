<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.destino.app.view.CasasController"
            prefWidth="850" prefHeight="500">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="12" left="12" bottom="8"/></padding>
            <Button text="← Volver" onAction="#onVolver"/>
            <Label text="Casas Destino" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="tablaCasas">
            <columns>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="160"/>
                <TableColumn fx:id="colSector" text="Sector" prefWidth="140"/>
                <TableColumn fx:id="colDia" text="Día" prefWidth="100"/>
                <TableColumn fx:id="colHora" text="Hora" prefWidth="80"/>
                <TableColumn fx:id="colActiva" text="Activa" prefWidth="70"/>
            </columns>
            <BorderPane.margin><Insets left="12" bottom="12"/></BorderPane.margin>
        </TableView>
    </center>

    <right>
        <VBox spacing="8" prefWidth="260">
            <padding><Insets top="0" right="12" bottom="12" left="12"/></padding>
            <Label text="Datos" style="-fx-font-weight: bold;"/>
            <TextField fx:id="campoNombre" promptText="Nombre"/>
            <TextField fx:id="campoDireccion" promptText="Dirección"/>
            <TextField fx:id="campoSector" promptText="Sector"/>
            <ComboBox fx:id="comboDia" promptText="Día de reunión"/>
            <TextField fx:id="campoHora" promptText="Hora (HH:mm)"/>
            <CheckBox fx:id="checkActiva" text="Activa" selected="true"/>
            <HBox spacing="8">
                <Button text="Nuevo" onAction="#onNuevo"/>
                <Button text="Guardar" onAction="#onGuardar" defaultButton="true"/>
                <Button text="Inactivar" onAction="#onInactivar"/>
            </HBox>
            <Label fx:id="etiquetaMensaje" wrapText="true"/>
        </VBox>
    </right>
</BorderPane>