<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.destino.app.view.MinisteriosController"
            prefWidth="820" prefHeight="480">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="12" left="12" bottom="8"/></padding>
            <Button text="← Volver" onAction="#onVolver"/>
            <Label text="Ministerios" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="tablaMinisterios">
            <columns>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="180"/>
                <TableColumn fx:id="colDescripcion" text="Descripción" prefWidth="280"/>
                <TableColumn fx:id="colActivo" text="Activo" prefWidth="70"/>
            </columns>
            <BorderPane.margin><Insets left="12" bottom="12"/></BorderPane.margin>
        </TableView>
    </center>

    <right>
        <VBox spacing="8" prefWidth="260">
            <padding><Insets top="0" right="12" bottom="12" left="12"/></padding>
            <Label text="Datos" style="-fx-font-weight: bold;"/>
            <TextField fx:id="campoNombre" promptText="Nombre"/>
            <TextField fx:id="campoDescripcion" promptText="Descripción"/>
            <Label text="Coordinador"/>
            <ComboBox fx:id="comboCoordinador" promptText="(opcional)"/>
            <CheckBox fx:id="checkActivo" text="Activo" selected="true"/>
            <HBox spacing="8">
                <Button text="Nuevo" onAction="#onNuevo"/>
                <Button text="Guardar" onAction="#onGuardar" defaultButton="true"/>
                <Button text="Inactivar" onAction="#onInactivar"/>
            </HBox>
            <Label fx:id="etiquetaMensaje" wrapText="true"/>
        </VBox>
    </right>
</BorderPane>