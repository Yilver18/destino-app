<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.destino.app.view.PersonasController"
            prefWidth="900" prefHeight="520">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="12" left="12" bottom="8"/></padding>
            <Button text="← Volver" onAction="#onVolver"/>
            <Label text="Gestión de personas" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="tablaPersonas">
            <columns>
                <TableColumn fx:id="colNombres" text="Nombres" prefWidth="140"/>
                <TableColumn fx:id="colApellidos" text="Apellidos" prefWidth="140"/>
                <TableColumn fx:id="colTipoDoc" text="Tipo" prefWidth="60"/>
                <TableColumn fx:id="colDocumento" text="Documento" prefWidth="110"/>
                <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="100"/>
                <TableColumn fx:id="colEstado" text="Estado" prefWidth="80"/>
            </columns>
            <BorderPane.margin><Insets left="12" bottom="12"/></BorderPane.margin>
        </TableView>
    </center>

    <right>
        <VBox spacing="8" prefWidth="280">
            <padding><Insets top="0" right="12" bottom="12" left="12"/></padding>
            <Label text="Datos" style="-fx-font-weight: bold;"/>
            <TextField fx:id="campoNombres" promptText="Nombres"/>
            <TextField fx:id="campoApellidos" promptText="Apellidos"/>
            <ComboBox fx:id="comboTipoDoc" promptText="Tipo de documento"/>
            <TextField fx:id="campoDocumento" promptText="Número de documento"/>
            <TextField fx:id="campoTelefono" promptText="Teléfono"/>
            <TextField fx:id="campoEmail" promptText="Email"/>
            <ComboBox fx:id="comboSexo" promptText="Sexo"/>
            <DatePicker fx:id="fechaNacimiento" promptText="Fecha de nacimiento"/>
            <CheckBox fx:id="checkConsentimiento" text="Acepta tratamiento de datos"/>
            <HBox spacing="8">
                <Button text="Nuevo" onAction="#onNuevo"/>
                <Button text="Guardar" onAction="#onGuardar" defaultButton="true"/>
                <Button text="Inactivar" onAction="#onInactivar"/>
            </HBox>
            <Label fx:id="etiquetaMensaje" wrapText="true"/>
        </VBox>
    </right>
</BorderPane>