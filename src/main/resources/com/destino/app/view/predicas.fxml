<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.destino.app.view.PredicasController"
            prefWidth="880" prefHeight="500">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="12" left="12" bottom="8"/></padding>
            <Button text="← Volver" onAction="#onVolver"/>
            <Label text="Prédicas — Video de la semana" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="tablaPredicas">
            <columns>
                <TableColumn fx:id="colActual" text="Actual" prefWidth="60"/>
                <TableColumn fx:id="colTitulo" text="Título" prefWidth="240"/>
                <TableColumn fx:id="colCreativo" text="Creativo" prefWidth="150"/>
                <TableColumn fx:id="colFecha" text="Publicada" prefWidth="100"/>
            </columns>
            <BorderPane.margin><Insets left="12" bottom="12"/></BorderPane.margin>
        </TableView>
    </center>

    <right>
        <VBox spacing="8" prefWidth="270">
            <padding><Insets top="0" right="12" bottom="12" left="12"/></padding>
            <Label text="Nueva prédica" style="-fx-font-weight: bold;"/>
            <TextField fx:id="campoTitulo" promptText="Título"/>
            <TextField fx:id="campoYoutube" promptText="Link de YouTube"/>
            <Label text="Creativo (opcional)"/>
            <ComboBox fx:id="comboCreativo" prefWidth="240"/>
            <DatePicker fx:id="fechaPublicacion" promptText="Fecha de publicación"/>
            <Button text="Registrar" onAction="#onRegistrar" defaultButton="true"/>
            <Separator/>
            <Button text="Marcar seleccionada como ACTUAL" onAction="#onMarcarActual"/>
            <Label fx:id="etiquetaMensaje" wrapText="true"/>
        </VBox>
    </right>
</BorderPane>