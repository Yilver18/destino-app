<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.destino.app.view.EscaneoController"
            prefWidth="640" prefHeight="600">

    <top>
        <VBox spacing="8">
            <padding><Insets top="12" left="12" right="12" bottom="8"/></padding>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button text="← Volver" onAction="#onVolver"/>
                <Label text="Asistencia por QR" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Sesión:"/>
                <ComboBox fx:id="comboSesion" prefWidth="380"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10" alignment="CENTER">
            <ImageView fx:id="imagenCamara" fitWidth="320" fitHeight="240" preserveRatio="true"/>
            <HBox spacing="8" alignment="CENTER">
                <Button fx:id="btnIniciar" text="Iniciar cámara" onAction="#onIniciar"/>
                <Button fx:id="btnDetener" text="Detener" onAction="#onDetener" disable="true"/>
            </HBox>
            <Separator/>
            <Label text="O escribe / escanea el código (lector USB):"/>
            <HBox spacing="8" alignment="CENTER">
                <TextField fx:id="campoCodigo" promptText="Código QR" prefWidth="320" onAction="#onCodigoManual"/>
                <Button text="Registrar" onAction="#onCodigoManual"/>
            </HBox>
            <Label fx:id="etiquetaMensaje" wrapText="true" style="-fx-font-size: 14px;"/>
        </VBox>
    </center>
</BorderPane>