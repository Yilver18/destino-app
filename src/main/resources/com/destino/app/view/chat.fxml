<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.destino.app.view.ChatController"
            prefWidth="760" prefHeight="540">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="12" left="12" bottom="8"/></padding>
            <Button text="← Volver" onAction="#onVolver"/>
            <Label text="Chat interno" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="8" prefWidth="240">
            <padding><Insets left="12" right="8" bottom="12"/></padding>
            <Label text="Conversaciones" style="-fx-font-weight: bold;"/>
            <ListView fx:id="listaConversaciones" prefHeight="280"/>
            <Separator/>
            <Label text="Nueva conversación"/>
            <ComboBox fx:id="comboPersona" prefWidth="220"/>
            <Button text="Iniciar chat" onAction="#onIniciar"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="8">
            <padding><Insets left="8" right="12" bottom="12"/></padding>
            <TextArea fx:id="areaMensajes" editable="false" wrapText="true" VBox.vgrow="ALWAYS"/>
            <HBox spacing="8">
                <TextField fx:id="campoMensaje" promptText="Escribe un mensaje..." HBox.hgrow="ALWAYS" onAction="#onEnviar"/>
                <Button text="Enviar" onAction="#onEnviar" defaultButton="true"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>