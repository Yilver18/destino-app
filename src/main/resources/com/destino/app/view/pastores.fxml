<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.destino.app.view.PastoresController"
            prefWidth="820" prefHeight="500">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="12" left="12" bottom="8"/></padding>
            <Button text="← Volver" onAction="#onVolver"/>
            <Label text="Pastores (Nosotros)" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="tablaPastores">
            <columns>
                <TableColumn fx:id="colOrden" text="Orden" prefWidth="60"/>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="220"/>
                <TableColumn fx:id="colCargo" text="Cargo" prefWidth="200"/>
            </columns>
            <BorderPane.margin><Insets left="12" bottom="12"/></BorderPane.margin>
        </TableView>
    </center>

    <right>
        <VBox spacing="8" prefWidth="280">
            <padding><Insets top="0" right="12" bottom="12" left="12"/></padding>
            <Label text="Datos" style="-fx-font-weight: bold;"/>
            <TextField fx:id="campoNombre" promptText="Nombre"/>
            <TextField fx:id="campoCargo" promptText="Cargo (ej. Pastor principal)"/>
            <TextField fx:id="campoFotoUrl" promptText="URL de foto"/>
            <TextArea fx:id="campoBiografia" promptText="Biografía" prefRowCount="4"/>
            <TextField fx:id="campoOrden" promptText="Orden (0, 1, 2...)"/>
            <HBox spacing="8">
                <Button text="Nuevo" onAction="#onNuevo"/>
                <Button text="Guardar" onAction="#onGuardar" defaultButton="true"/>
                <Button text="Eliminar" onAction="#onEliminar"/>
            </HBox>
            <Label fx:id="etiquetaMensaje" wrapText="true"/>
        </VBox>
    </right>
</BorderPane>