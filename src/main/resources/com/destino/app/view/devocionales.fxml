<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.destino.app.view.DevocionalesController"
            prefWidth="880" prefHeight="540">

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT">
            <padding><Insets top="12" left="12" bottom="8"/></padding>
            <Button text="← Volver" onAction="#onVolver"/>
            <Label text="Devocionales" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <TableView fx:id="tablaDevocionales">
            <columns>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="220"/>
                <TableColumn fx:id="colMes" text="Mes" prefWidth="60"/>
                <TableColumn fx:id="colAnio" text="Año" prefWidth="70"/>
                <TableColumn fx:id="colPrecio" text="Precio" prefWidth="100"/>
                <TableColumn fx:id="colDestacado" text="Destacado" prefWidth="80"/>
            </columns>
            <BorderPane.margin><Insets left="12" bottom="12"/></BorderPane.margin>
        </TableView>
    </center>

    <right>
        <VBox spacing="8" prefWidth="280">
            <padding><Insets top="0" right="12" bottom="12" left="12"/></padding>
            <Label text="Datos" style="-fx-font-weight: bold;"/>
            <TextField fx:id="campoNombre" promptText="Nombre"/>
            <TextArea fx:id="campoDescripcion" promptText="Descripción" prefRowCount="2"/>
            <HBox spacing="8">
                <ComboBox fx:id="comboMes" promptText="Mes" prefWidth="90"/>
                <TextField fx:id="campoAnio" promptText="Año" prefWidth="90"/>
            </HBox>
            <TextField fx:id="campoPrecio" promptText="Precio (ej. 15000)"/>
            <TextField fx:id="campoImagenUrl" promptText="URL de imagen"/>
            <CheckBox fx:id="checkDestacado" text="Destacado (del mes)"/>
            <CheckBox fx:id="checkActivo" text="Activo" selected="true"/>
            <HBox spacing="8">
                <Button text="Nuevo" onAction="#onNuevo"/>
                <Button text="Guardar" onAction="#onGuardar" defaultButton="true"/>
                <Button text="Inactivar" onAction="#onInactivar"/>
            </HBox>
            <Label fx:id="etiquetaMensaje" wrapText="true"/>
        </VBox>
    </right>
</BorderPane>